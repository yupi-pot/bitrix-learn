# ============================================================
# Битрикс — ядро игнорируем целиком
# ------------------------------------------------------------
# Весь www/bitrix/ — это ядро CMS (~100 МБ файлов, обновляется
# автоматически Битриксом). Версионировать его бессмысленно.
#
# Наш код живёт ТОЛЬКО в:
#   - www/local/        (шаблоны, компоненты, init.php)
#   - www/index.php и других страницах в корне
#   - docs/, config/, Dockerfile, docker-compose.yml и т.п.
# ============================================================
www/bitrix/

# ============================================================
# Загрузки и пользовательский контент
# Картинки, документы, файлы, которые загружают через админку.
# В git их не храним — слишком тяжёлые и непредсказуемые.
# ============================================================
www/upload/

# ============================================================
# База данных (Docker volume)
# Содержит сами файлы MySQL. Никогда не в git.
# ============================================================
db_data/

# ============================================================
# Бэкапы
# Дампы БД могут быть огромными и часто содержат ПДн.
# ============================================================
backup.sql
*.sql.gz
*.sql.bz2

# ============================================================
# Логи
# ============================================================
*.log
logs/

# ============================================================
# Локальные конфиги и секреты
# ============================================================
.env
.env.local

# ============================================================
# Состояние редакторов и инструментов
# ============================================================
.claude/
.idea/
.vscode/
*.swp
*~

# ============================================================
# OS-мусор
# ============================================================
.DS_Store
Thumbs.db
